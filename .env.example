# GlobeCloud — Enterprise Production

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

HOST=0.0.0.0
PORT=8000
DATA_DIR=data

PRODUCT_NAME=GlobeCloud
PRODUCT_TAGLINE=Global database routing with grounded AI

# PostgreSQL (production / docker-compose). For local dev without Postgres,
# start-clean.sh auto-falls back to sqlite:///data/globe.db
DATABASE_URL=postgresql+psycopg://globe:globe@localhost:5432/globe_platform
# Leave empty to use DATABASE_URL (single local Postgres). Docker compose uses :5433.
REGIONAL_DATABASE_URL=
ENVIRONMENT=development

# regional | gateway
DEPLOYMENT_MODE=regional
REGION_ID=us-east-1
PEER_URLS=
PUBLIC_URL=

GATEWAY_PEERS=us-east-1:http://localhost:8001,eu-west-1:http://localhost:8002,ap-south-1:http://localhost:8003

API_KEY=
API_KEYS=
REPLICATION_SECRET=dev-replication-secret
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Email
RESEND_API_KEY=
EMAIL_FROM=GlobeCloud <noreply@globecloud.io>

# Observability
SENTRY_DSN=

AUTH_REQUIRED=true
JWT_SECRET=
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8000

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

SEED_DEMO_DATA=0
CATALOG_SEED_FILE=seed/catalog.json
