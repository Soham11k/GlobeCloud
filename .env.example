# GlobeCloud — Enterprise Production

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

HOST=0.0.0.0
PORT=8000
DATA_DIR=data

PRODUCT_NAME=GlobeCloud
PRODUCT_TAGLINE=Global database routing with grounded AI

# PostgreSQL / Supabase (production). For local dev without Postgres,
# start-clean.sh auto-falls back to sqlite:///data/globe.db
#
# Local Docker:  postgresql+psycopg://globe:globe@localhost:5432/globe_platform
# Homebrew Mac:   postgresql+psycopg://YOUR_USER@localhost:5432/globe_platform
#
# Supabase (hosted Postgres — paste from Dashboard → Project Settings → Database):
#   SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# GlobeCloud normalizes postgres:// → postgresql+psycopg:// and adds sslmode=require for *.supabase.co hosts.
# Run: CREATE EXTENSION IF NOT EXISTS vector; in Supabase SQL Editor before first start.
# Leave REGIONAL_DATABASE_URL empty to store platform + regional tables in one Supabase database.
SUPABASE_DATABASE_URL=
DATABASE_URL=postgresql+psycopg://globe:globe@localhost:5432/globe_platform
# Leave empty to use DATABASE_URL (single DB). Docker compose uses a separate regional URL on :5433.
REGIONAL_DATABASE_URL=
ENVIRONMENT=development

# Set to 1 for local production demos: allows public GET on /api/v1/* read routes (metrics, catalog, etc.)
GLOBE_PUBLIC_READ=0

# regional | gateway
DEPLOYMENT_MODE=regional
REGION_ID=us-east-1
PEER_URLS=
PUBLIC_URL=

GATEWAY_PEERS=us-east-1:http://localhost:8001,eu-west-1:http://localhost:8002,ap-south-1:http://localhost:8003

API_KEY=
API_KEYS=
REPLICATION_SECRET=dev-replication-secret
# Optional locally — leave empty to use in-memory rate limits (docker-compose sets this in containers)
REDIS_URL=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=

# Email
RESEND_API_KEY=
EMAIL_FROM=GlobeCloud <noreply@globecloud.io>

# Observability
SENTRY_DSN=

AUTH_REQUIRED=true
JWT_SECRET=
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
# OAuth — create apps at:
#   Google: https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web application)
#   GitHub: https://github.com/settings/developers (OAuth App)
# Redirect URIs (register BOTH localhost and 127.0.0.1 if you use either):
#   http://localhost:8000/auth/oauth/callback/google
#   http://127.0.0.1:8000/auth/oauth/callback/google
#   http://localhost:8000/auth/oauth/callback/github
#   http://127.0.0.1:8000/auth/oauth/callback/github
# OAUTH_REDIRECT_BASE_URL must match the origin you sign in from (localhost vs 127.0.0.1).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000

CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

SEED_DEMO_DATA=0
CATALOG_SEED_FILE=seed/catalog.json
