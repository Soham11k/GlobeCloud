# GlobeCloud — Global Product

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

HOST=0.0.0.0
PORT=8000
DATA_DIR=data

PRODUCT_NAME=GlobeCloud
PRODUCT_TAGLINE=Global database routing with grounded AI

# local | regional | gateway
DEPLOYMENT_MODE=local

# Regional backend settings
REGION_ID=us-east-1
PEER_URLS=
PUBLIC_URL=

# Gateway settings (DEPLOYMENT_MODE=gateway)
GATEWAY_PEERS=us-east-1:https://globecloud-us.fly.dev,eu-west-1:https://globecloud-eu.fly.dev,ap-south-1:https://globecloud-ap.fly.dev

# Production auth (required on Fly)
API_KEY=
# Comma-separated additional keys (rotation / per-customer)
API_KEYS=
REPLICATION_SECRET=

CORS_ORIGINS=*

# Catalog seeding (local dev)
# SEED_DEMO_DATA=1 loads demo SKUs; set to 0 to skip
SEED_DEMO_DATA=1
# Optional JSON catalog loaded on empty DB (requires SEED_DEMO_DATA=0 or empty demo)
# CATALOG_SEED_FILE=seed/catalog.json
